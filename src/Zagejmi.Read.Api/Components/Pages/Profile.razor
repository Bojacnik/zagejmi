@page "/profile"
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@attribute [Authorize]

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject HttpClient Http

<PageTitle>Profile</PageTitle>

<div class="w-full max-w-4xl mx-auto p-8">

    <div class="flex justify-between items-center mb-8">
        <h1 class="text-4xl font-bold text-text-default">Your Profile</h1>
        <button @onclick="HandleLogout" disabled="@isLoggingOut"
                class="px-4 py-2 font-semibold text-text-default bg-primary-800 hover:bg-primary-700 border border-accent-700 rounded-lg transition-colors shadow-md disabled:opacity-50 disabled:cursor-not-allowed">
            @if (isLoggingOut)
            {
                <span>Logging out...</span>
            }
            else
            {
                <span>Logout</span>
            }
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center p-8 bg-primary-900/50 rounded-2xl border border-accent-700/50">
            <p class="text-text-muted animate-pulse">Loading profile...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-4 text-sm text-red-400 bg-red-900/30 border border-red-400/50 rounded-lg" role="alert">
            <h3 class="font-bold">Error Loading Profile</h3>
            <p>@errorMessage</p>
        </div>
    }
    else if ( /*person != null*/ true)
    {
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-1">
                <div
                    class="bg-primary-900/50 rounded-2xl border border-accent-700/50 shadow-xl p-6 text-center flex flex-col items-center">
                    <img class="w-32 h-32 rounded-full mb-4 border-4 border-accent-600 shadow-lg" src="img/cat.jpg"
                         alt="Profile Picture">
                    <h2 class="text-2xl font-bold text-text-default"><!--@person.FirstName @person.LastName--></h2>
                    <p class="text-text-muted"><!--@@@person.UserName--></p>
                </div>
            </div>
            <div class="md:col-span-2">
                <div class="bg-primary-900/50 rounded-2xl border border-accent-700/50 shadow-xl p-6 space-y-6">
                    <div>
                        <h3 class="text-xl font-bold text-text-default border-b border-accent-800/50 pb-2 mb-4">Personal
                            Information</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
                            <div>
                                <label class="block text-sm font-medium text-text-muted">First Name</label>
                                <p class="text-text-default text-lg"><!--@person.FirstName--></p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-text-muted">Last Name</label>
                                <p class="text-text-default text-lg"><!--@person.LastName--></p>
                            </div>
                            <div class="sm:col-span-2">
                                <label class="block text-sm font-medium text-text-muted">Email</label>
                                <p class="text-text-default text-lg"><!--@person.Email--></p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-text-muted">Birth Date</label>
                                <p class="text-text-default text-lg"><!--@person.BirthDate.ToShortDateString()--></p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-text-muted">Gender</label>
                                <p class="text-text-default text-lg"><!--@person.Gender--></p>
                            </div>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-text-default border-b border-accent-800/50 pb-2 mb-4">Account
                            Statistics</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-text-muted">Goin Balance</label>
                                <p class="text-3xl font-bold text-accent-400"><!--@person.GoinAmount--></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

