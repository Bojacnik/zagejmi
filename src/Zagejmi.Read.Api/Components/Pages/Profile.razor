    private async Task HandleLogout()
    {
        if (isLoggingOut) return;

        isLoggingOut = true;

        try
        {
            await Http.PostAsync("api/v1/auth/logout", null);

            // Redirect regardless of success
            NavigationManager.NavigateTo("/", true);
        }
        catch
        {
            // On error, still redirect
            NavigationManager.NavigateTo("/", true);
        }
    }

}
