@page "/"

<PageTitle>Your E-Girl Companion</PageTitle>

<div class="font-sans text-gray-800 text-center">
    <div class="p-8 md:p-12 bg-pink-100 rounded-2xl mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-pink-600 mb-2">Hello, Gorgeous!</h1>
        <p class="text-lg text-gray-700">Find your perfect e-girl companion for unforgettable gaming sessions, heartfelt
            chats, and endless fun. Your next online bestie is just a click away.</p>
    </div>
    
    <div class="py-10 px-5">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-gray-800">Our Top E-Girls</h2>
        <div class="flex flex-wrap justify-center gap-8">
            <!-- Employee Card 1 -->
            <div
                class="bg-white rounded-2xl shadow-lg p-6 w-72 transition-transform duration-300 ease-in-out hover:-translate-y-2 hover:shadow-xl">
                <img src="https://via.placeholder.com/150" alt="E-Girl Luna"
                     class="w-36 h-36 rounded-full object-cover mx-auto mb-4 border-4 border-pink-100"/>
                <h3 class="text-2xl font-bold mb-2 text-pink-600">Luna</h3>
                <p class="text-gray-600">Your quirky and fun-loving gaming partner.</p>
            </div>
            <!-- Employee Card 2 -->
            <div
                class="bg-white rounded-2xl shadow-lg p-6 w-72 transition-transform duration-300 ease-in-out hover:-translate-y-2 hover:shadow-xl">
                <img src="https://via.placeholder.com/150" alt="E-Girl Stella"
                     class="w-36 h-36 rounded-full object-cover mx-auto mb-4 border-4 border-pink-100"/>
                <h3 class="text-2xl font-bold mb-2 text-pink-600">Stella</h3>
                <p class="text-gray-600">Loves deep conversations and cozy game nights.</p>
            </div>
            <!-- Employee Card 3 -->
            <div
                class="bg-white rounded-2xl shadow-lg p-6 w-72 transition-transform duration-300 ease-in-out hover:-translate-y-2 hover:shadow-xl">
                <img src="https://via.placeholder.com/150" alt="E-Girl Nova"
                     class="w-36 h-36 rounded-full object-cover mx-auto mb-4 border-4 border-pink-100"/>
                <h3 class="text-2xl font-bold mb-2 text-pink-600">Nova</h3>
                <p class="text-gray-600">Competitive and always up for a challenge.</p>
            </div>
        </div>
    </div>

    <div class="py-12 px-5 bg-yellow-100 my-8 rounded-2xl">
        <h2 class="text-3xl font-bold text-yellow-800">Sending You a Warm Hug</h2>
        <p class="text-gray-700 mt-2">We're all about creating a positive and uplifting space. Whatever you're looking
            for, we're happy to have you here!</p>
    </div>

    <footer class="py-10 px-5 bg-purple-100 rounded-2xl">
        <h2 class="text-2xl font-bold mb-4">Ready to Join Us?</h2>
        <a href="/become-an-egirl"
           class="inline-block py-3 px-8 text-lg font-bold text-white bg-purple-500 rounded-full no-underline transition-colors duration-300 hover:bg-purple-600">Become
            an E-Girl</a>
    </footer>
</div>
