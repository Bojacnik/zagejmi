@page "/logout"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<div class="w-full h-full flex flex-col justify-center items-center p-4">
    <div class="text-center">
        <h1 class="text-2xl font-bold text-gray-100">Logging out...</h1>
    </div>
</div>

@code {

    protected override async Task OnInitializedAsync()
    {
        await HandleLogout();
    }

    private async Task HandleLogout()
    {
        try
        {
            HttpClient client = HttpClientFactory.CreateClient();
            string logoutUrl = NavigationManager.ToAbsoluteUri("/api/v1/auth/logout").ToString();
            await client.PostAsync(logoutUrl, null);

            // Redirect to homepage with full page reload
            NavigationManager.NavigateTo("/", true);
        }
        catch
        {
            // On error, still redirect
            NavigationManager.NavigateTo("/", true);
        }
    }

}