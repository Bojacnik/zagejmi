@page "/login"
@using System.Web
@inject NavigationManager NavManager

<div class="w-full h-full flex flex-col justify-center items-center p-4">
    <form action="http://localhost:5178/api/user/login" method="post"
          class="w-full max-w-sm p-8 space-y-6 bg-primary-900 rounded-xl border border-accent-700/50 shadow-2xl shadow-accent-900/30">

        <input type="hidden" name="SuccessUrl" value="@_successUrl" />
        <input type="hidden" name="FailureUrl" value="@_failureUrl" />

        <header class="text-center">
            <h1 class="text-4xl font-bold text-gray-100">Welcome Back</h1>
            <p class="text-gray-400 mt-2">Please enter your credentials to login.</p>
        </header>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="p-4 text-sm text-red-400 bg-red-900/30 border border-red-400/50 rounded-lg" role="alert">
                <p>@ErrorMessage</p>
            </div>
        }

        <div class="space-y-4">
            <div>
                <label for="username" class="sr-only">Username</label>
                <input name="Username" type="text" id="username" placeholder="Username" required
                       class="w-full px-4 py-3 bg-gray-200 border-2 border-gray-300 rounded-lg text-black placeholder:text-gray-500 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-all"/>
            </div>

            <div>
                <label for="password" class="sr-only">Password</label>
                <input name="Password" type="password" id="password" placeholder="Password" required
                       class="w-full px-4 py-3 bg-gray-200 border-2 border-gray-300 rounded-lg text-black placeholder:text-gray-500 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-all"/>
            </div>
        </div>

        <div class="flex flex-col gap-4 pt-4">
            <button type="submit"
                    class="w-full px-4 py-3 font-bold text-lg text-white bg-accent-600 hover:bg-accent-700 rounded-lg transition-colors shadow-lg shadow-accent-800/40 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-primary-900 focus:ring-accent-500">
                Login
            </button>
            <div class="text-center">
                <a href="/register" class="text-sm font-medium text-accent-400 hover:text-accent-300 hover:underline transition-colors">
                    Don't have an account? Register
                </a>
            </div>
        </div>
    </form>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? ErrorMessage { get; set; }

    private string _successUrl = "";
    private string _failureUrl = "";

    protected override void OnInitialized()
    {
        _successUrl = NavManager.ToAbsoluteUri(ReturnUrl ?? "/profile").ToString();

        var failureUri = new UriBuilder(NavManager.ToAbsoluteUri(NavManager.Uri));
        var query = HttpUtility.ParseQueryString(failureUri.Query);
        query.Remove("error");
        if (!string.IsNullOrEmpty(ReturnUrl)) {
            query["ReturnUrl"] = ReturnUrl;
        } else {
            query.Remove("ReturnUrl");
        }
        failureUri.Query = query.ToString();
        _failureUrl = failureUri.ToString();
    }
}
